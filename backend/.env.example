# Flask
FLASK_DEBUG=1
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5001

# Security — REQUIRED in production (auto-generated in debug mode if missing)
SECRET_KEY=your-secret-key-here

# Database — REQUIRED in production
DATABASE_URL=postgresql+psycopg://postgres:yourpassword@127.0.0.1:5432/diabetes_expert_system

# Database behaviour
DB_AUTO_CREATE=0
SEED_DEMO_DATA=1

# Fallback to SQLite when PostgreSQL is unavailable (dev convenience)
DB_FALLBACK_ENABLED=1
DB_FALLBACK_AUTO_CREATE=1
DB_FALLBACK_SEED=1

# Connection pool tuning (optional)
# DB_POOL_SIZE=5
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# DB_MAX_OVERFLOW=10

# Rate limiting (optional)
# RATELIMIT_DEFAULT=200 per minute
# RATELIMIT_STORAGE_URI=memory://

# CORS
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
