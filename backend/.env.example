FLASK_DEBUG=true
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_SECONDS=3600
JWT_REFRESH_EXPIRES_SECONDS=604800

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/diabetes_expert_system
SQLALCHEMY_ECHO=false
DB_AUTO_CREATE=false
SEED_DEMO_DATA=true
DB_FALLBACK_ENABLED=false
DB_FALLBACK_URL=sqlite:///dev_fallback.db
DB_FALLBACK_AUTO_CREATE=true
DB_FALLBACK_SEED=true

CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
