{
  "info": {
    "_postman_id": "8f7a2cf1-4f08-4e60-9b60-2f65f043f4a3",
    "name": "Diabetes Expert System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API smoke collection for auth, patients, diagnosis, rules, and admin endpoints."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rootUrl}}/health",
              "host": ["{{rootUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health endpoint is OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Doctor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{doctorPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Doctor login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('accessToken', json.data.access_token || '');",
                  "  pm.environment.set('refreshToken', json.data.refresh_token || '');",
                  "  pm.environment.set('currentUserId', String(json.data.user?.id || ''));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('accessToken', json.data.access_token || '');",
                  "  pm.environment.set('refreshToken', json.data.refresh_token || '');",
                  "  pm.environment.set('currentUserId', String(json.data.user?.id || ''));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Patient login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('accessToken', json.data.access_token || '');",
                  "  pm.environment.set('refreshToken', json.data.refresh_token || '');",
                  "  pm.environment.set('patientId', String(json.data.user?.patient_id || pm.environment.get('patientId') || ''));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('accessToken', json.data.access_token || pm.environment.get('accessToken'));",
                  "  pm.environment.set('refreshToken', json.data.refresh_token || pm.environment.get('refreshToken'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Postman Test Patient\",\n  \"gender\": \"male\",\n  \"date_of_birth\": \"1999-11-03\",\n  \"phone\": \"012345678\",\n  \"notes\": \"Created from Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/",
              "host": ["{{baseUrl}}"],
              "path": ["patients", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create patient success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('patientId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["patients", ""],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Patient Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}"]
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Updated from Postman\",\n  \"phone\": \"099999999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}"]
            }
          }
        },
        {
          "name": "Add Symptom",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symptom_code\": \"fatigue\",\n  \"symptom_name\": \"Fatigue\",\n  \"present\": true,\n  \"severity\": 6,\n  \"notes\": \"Mild fatigue for 3 days\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/symptoms",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "symptoms"]
            }
          }
        },
        {
          "name": "Add Lab Result",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"test_name\": \"fasting_glucose\",\n  \"test_value\": 132,\n  \"unit\": \"mg/dL\",\n  \"reference_range\": \"70-99\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/lab-results",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "lab-results"]
            }
          }
        },
        {
          "name": "Get Patient History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}", "history"]
            }
          }
        }
      ]
    },
    {
      "name": "Diagnosis",
      "item": [
        {
          "name": "Run Diagnosis (Doctor/Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": {{patientId}},\n  \"fasting_glucose\": 140,\n  \"hba1c\": 6.8,\n  \"frequent_urination\": true,\n  \"excessive_thirst\": true,\n  \"symptoms\": {\n    \"fatigue\": true,\n    \"blurred_vision\": false\n  },\n  \"risk_factors\": {\n    \"family_history\": true,\n    \"obesity\": false\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/diagnosis/",
              "host": ["{{baseUrl}}"],
              "path": ["diagnosis", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Diagnosis run success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('diagnosisId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Review Queue",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/diagnosis/review?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["diagnosis", "review"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Review Diagnosis",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"review_note\": \"Reviewed from Postman\",\n  \"is_urgent\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/diagnosis/{{diagnosisId}}/review",
              "host": ["{{baseUrl}}"],
              "path": ["diagnosis", "{{diagnosisId}}", "review"]
            }
          }
        },
        {
          "name": "My Diagnoses (Patient)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/diagnosis/mine",
              "host": ["{{baseUrl}}"],
              "path": ["diagnosis", "mine"]
            }
          }
        }
      ]
    },
    {
      "name": "Rules",
      "item": [
        {
          "name": "List Rules",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/rules/?include_archived=false",
              "host": ["{{baseUrl}}"],
              "path": ["rules", ""],
              "query": [
                { "key": "include_archived", "value": "false" }
              ]
            }
          }
        },
        {
          "name": "Create Rule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Rule\",\n  \"category\": \"diagnosis\",\n  \"certainty_factor\": 0.75,\n  \"priority\": \"high\",\n  \"status\": \"active\",\n  \"explanation\": \"Rule created from Postman\",\n  \"conditions\": [\"fasting_glucose >= 126\", \"hba1c >= 6.5\"],\n  \"conclusion\": \"diabetes\",\n  \"recommendation\": \"Consult doctor and repeat labs.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rules/",
              "host": ["{{baseUrl}}"],
              "path": ["rules", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create rule success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('ruleId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Rule",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\",\n  \"priority\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rules/{{ruleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rules", "{{ruleId}}"]
            }
          }
        },
        {
          "name": "Rule Versions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/rules/{{ruleId}}/versions?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["rules", "{{ruleId}}", "versions"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    },
